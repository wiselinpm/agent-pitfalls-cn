---
/**
 * /pitfalls 列表页（首页 / 带搜索）
 *
 * 改造要点：
 *   - 首屏只 SSR 前 50 条 + 筛选 UI；不预加载全部 8K 数据
 *   - 客户端搜索/筛选：fetch /agent-pitfalls-cn/search-index.json，按需 lazy load
 *   - 筛选/搜索状态写入 URL query string，刷新可恢复
 *   - 无 JS 用户：仍能看到首屏 50 条 + 分页链接（下一页见 /pitfalls/page/2/）
 *   - 移除了原 stagger 动画 + 每条 5 个 data-* 属性（搜索走 manifest）
 *
 * UI shell + labels 抽出到 <PitfallsFilter /> 组件，单一来源是 utils/labels.ts
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { paginate, DEFAULT_PER_PAGE } from '../../utils/paginate';
import PitfallsFilter from '../../components/PitfallsFilter.astro';

const all = (await getCollection('pitfalls')).sort(
  (a, b) => +new Date(b.data.discovered_at ?? 0) - +new Date(a.data.discovered_at ?? 0),
);

const first = paginate(all, 1, DEFAULT_PER_PAGE);
const { items: pageItems, totalPages, total } = first;

const categories = Array.from(new Set(all.flatMap((p) => p.data.categories))).sort();
const platforms = Array.from(new Set(all.flatMap((p) => p.data.platforms))).sort();

const severityCounts = {
  critical: all.filter((p) => p.data.severity === 'critical').length,
  high: all.filter((p) => p.data.severity === 'high').length,
  medium: all.filter((p) => p.data.severity === 'medium').length,
  low: all.filter((p) => p.data.severity === 'low').length,
};
---
<BaseLayout title="避坑库 · Agent Pitfalls" description="所有已收录的 agent 开发避坑条目，支持搜索、筛选、分类">
  <PitfallsFilter
    categories={categories}
    platforms={platforms}
    severityCounts={severityCounts}
    total={total}
    totalPages={totalPages}
    pageItems={pageItems.map((p) => ({
      id: p.id,
      data: {
        title: p.data.title,
        summary: p.data.summary,
        severity: p.data.severity,
        platforms: p.data.platforms,
        categories: p.data.categories,
        discovered_at: p.data.discovered_at as string | undefined,
        verified: p.data.verified,
      }
    }))}
  />
</BaseLayout>