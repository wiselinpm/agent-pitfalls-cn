---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORY_LABELS, SEVERITY_LABELS } from '../utils/labels';
const categories = Object.entries(CATEGORY_LABELS);
const severities = Object.entries(SEVERITY_LABELS);
---
<BaseLayout title="数据 Schema · Agent Pitfalls">
  <article class="prose-tight max-w-4xl">
    <header class="mb-8">
      <span class="eyebrow">SCHEMA</span>
      <h1 class="mt-3 text-[32px] font-semibold leading-tight text-ink">数据 Schema</h1>
      <p class="mt-3 text-[15px] leading-relaxed text-slate">
        所有避坑条目都遵循同一份 schema（由 <code>web/src/content.config.ts</code> 定义并强制）。
        这份文档同步人类可读版本。
      </p>
    </header>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">01</span>
        <h2>Pitfall（避坑条目）</h2>
      </div>
      <div class="mt-4 overflow-x-auto rounded-lg border border-lavender-mist">
        <table class="w-full text-[13px]">
          <thead class="bg-lavender-mist/40 text-left text-[12px] uppercase tracking-[0.056em] text-fog">
            <tr>
              <th class="px-4 py-2.5 font-semibold">字段</th>
              <th class="px-4 py-2.5 font-semibold">类型</th>
              <th class="px-4 py-2.5 font-semibold">必填</th>
              <th class="px-4 py-2.5 font-semibold">说明</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-lavender-mist text-slate">
            <tr><td class="px-4 py-2.5 font-mono text-ink">title</td><td class="px-4 py-2.5">string (4-120)</td><td class="px-4 py-2.5 font-mono text-mist">✓</td><td class="px-4 py-2.5">一句话描述问题</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">summary</td><td class="px-4 py-2.5">string (10-300)</td><td class="px-4 py-2.5 font-mono text-mist">✓</td><td class="px-4 py-2.5">2-3 句概览</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">severity</td><td class="px-4 py-2.5">enum</td><td class="px-4 py-2.5 font-mono text-mist">✓</td><td class="px-4 py-2.5"><code>critical</code> / <code>high</code> / <code>medium</code> / <code>low</code></td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">platforms</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">受影响的 agent 平台</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">categories</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">分类标签（见下表）</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">symptoms</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">用户/Agent 看到的现象</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">root_causes</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">为什么发生</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">fixes</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">具体修复步骤</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">references</td><td class="px-4 py-2.5">object[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">公开来源链接</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">tags</td><td class="px-4 py-2.5">string[]</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">自由标签</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">discovered_at</td><td class="px-4 py-2.5">ISO date</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">首次发现日期</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">verified</td><td class="px-4 py-2.5">boolean</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">是否被人工复核</td></tr>
            <tr><td class="px-4 py-2.5 font-mono text-ink">contributor</td><td class="px-4 py-2.5">string</td><td class="px-4 py-2.5"></td><td class="px-4 py-2.5">贡献者 GitHub handle</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">02</span>
        <h2>分类取值</h2>
      </div>
      <div class="mt-4 overflow-x-auto rounded-lg border border-lavender-mist">
        <table class="w-full text-[13px]">
          <thead class="bg-lavender-mist/40 text-left text-[12px] uppercase tracking-[0.056em] text-fog">
            <tr>
              <th class="px-4 py-2.5 font-semibold">Slug（英文）</th>
              <th class="px-4 py-2.5 font-semibold">中文标签</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-lavender-mist">
            {categories.map(([slug, label]) => (
              <tr>
                <td class="px-4 py-2 font-mono text-ink">{slug}</td>
                <td class="px-4 py-2 text-slate">{label}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">03</span>
        <h2>严重程度定义</h2>
      </div>
      <ul class="mt-4">
        <li><span class="badge badge-critical mr-2">严重</span>数据丢失、安全漏洞、生产事故</li>
        <li><span class="badge badge-high mr-2">高</span>默认配置下大概率触发，难以绕过</li>
        <li><span class="badge badge-medium mr-2">中</span>特定条件下触发，规避方案存在</li>
        <li><span class="badge badge-low mr-2">低</span>体验/性能问题，影响有限</li>
      </ul>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">04</span>
        <h2>最小可提交 frontmatter</h2>
      </div>
      <div class="code-block mt-4">
<pre class="m-0 border-0 p-0 font-mono text-[13px] leading-relaxed shadow-none" style="background: transparent;"><span class="tok-key">title</span>: <span class="tok-string">一句话描述问题</span>
<span class="tok-key">summary</span>: <span class="tok-string">2-3 句概览</span>
<span class="tok-key">severity</span>: <span class="tok-bool">high</span>
<span class="tok-key">fixes</span>:
  - <span class="tok-string">至少一条可执行修复</span>
<span class="tok-key">references</span>:
  - <span class="tok-key">title</span>: <span class="tok-string">来源标题</span>
    <span class="tok-key">url</span>: <span class="tok-string">https://example.com/issue/123</span></pre>
      </div>
    </section>
  </article>
</BaseLayout>