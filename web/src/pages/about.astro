---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/path';
---
<BaseLayout title="关于 · Agent Pitfalls">
  <article class="prose-tight max-w-3xl">
    <header class="mb-8">
      <span class="eyebrow">ABOUT</span>
      <h1 class="mt-3 text-[32px] font-semibold leading-tight text-ink">关于 Agent Pitfalls</h1>
      <p class="mt-3 text-[15px] leading-relaxed text-slate">
        一个由社区驱动的开源项目，目标是把全网关于 AI Agent 开发的「坑」（pitfall / gotcha / footgun）汇总到一处，
        提供可复现的症状、根因、修复方案和参考链接。
      </p>
    </header>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">01</span>
        <h2>为什么不直接搜索</h2>
      </div>
      <ul class="mt-4">
        <li>信息分散在 GitHub Issues、官方博客、HN、Reddit、知乎等十几个平台</li>
        <li>很多问题只在「复现 + 修复」类长帖的评论区出现</li>
        <li>同一根因常被反复踩到，每次都重新搜索</li>
        <li>开源生态需要一个<strong>中立、可审计、可贡献</strong>的资料库</li>
      </ul>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">02</span>
        <h2>数据流</h2>
      </div>
      <ol class="mt-4 list-none space-y-2 p-0">
        <li class="flex gap-3 rounded-lg border border-lavender-mist bg-paper p-3.5 text-[13px] leading-relaxed text-slate">
          <span class="font-mono text-mist">[01]</span>
          <span><strong class="text-ink">采集</strong> — Python 抓取脚本位于 <code>collectors/</code>，可重跑</span>
        </li>
        <li class="flex gap-3 rounded-lg border border-lavender-mist bg-paper p-3.5 text-[13px] leading-relaxed text-slate">
          <span class="font-mono text-mist">[02]</span>
          <span><strong class="text-ink">规范化</strong> — 统一为 Markdown + frontmatter（见 <code>docs/SCHEMA.md</code>）</span>
        </li>
        <li class="flex gap-3 rounded-lg border border-lavender-mist bg-paper p-3.5 text-[13px] leading-relaxed text-slate">
          <span class="font-mono text-mist">[03]</span>
          <span><strong class="text-ink">校验</strong> — CI 校验 schema、最少字段数、来源链接可访问</span>
        </li>
        <li class="flex gap-3 rounded-lg border border-lavender-mist bg-paper p-3.5 text-[13px] leading-relaxed text-slate">
          <span class="font-mono text-mist">[04]</span>
          <span><strong class="text-ink">发布</strong> — Astro 静态站点，部署到 GitHub Pages</span>
        </li>
      </ol>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">03</span>
        <h2>协议</h2>
      </div>
      <p class="mt-4">
        本项目代码采用 <a href={withBase('/LICENSE')}>MIT</a> 协议；
        收录的内容如有第三方来源，引用时遵循各自来源的协议（多数为 fair use / CC-BY 范畴）。
      </p>
    </section>

    <section>
      <div class="flex items-baseline gap-3">
        <span class="font-mono text-[12px] text-mist">04</span>
        <h2>如何参与</h2>
      </div>
      <p class="mt-4">
        详见 <a href={withBase('/contributing')}>贡献指南</a> — 哪怕只是订正一个错别字也欢迎 PR。
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-x-7 gap-y-3">
        <a href={withBase('/contributing')} class="link-cta">贡献指南</a>
        <a href={withBase('/pitfalls')} class="link-cta">浏览避坑库</a>
        <a href={withBase('/schema')} class="link-cta">Schema 文档</a>
      </div>
    </section>
  </article>
</BaseLayout>